# Copy to .env to enable REAL Google login locally (`make start` reads it).
# Without a .env, `make start` runs in dev-auth mode (no Google needed).

# Turn OFF dev-auth so the server-mediated Google flow is used.
DROP_DEV_AUTH=0

# From your Google Cloud "Web application" OAuth client (see SETUP_GOOGLE.md).
DROP_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
DROP_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Must match the API's URL; its /auth/callback is the registered redirect URI.
# (8473 is the Makefile's default API port; change both together if you override it.)
DROP_PUBLIC_URL=http://localhost:8473

# Random secret that signs Drop session tokens.  Generate:  openssl rand -hex 32
DROP_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Restrict to your Workspace domain (empty = any Google account).
DROP_ALLOWED_DOMAINS=paytm.com

# Optional: restrict to specific people (comma-separated). Empty = no per-email
# limit (domain rule still applies). Applied on top of DROP_ALLOWED_DOMAINS.
# DROP_ALLOWED_EMAILS=abhimanyu.rathore@paytm.com,teammate@paytm.com

# If your network does TLS inspection (Zscaler), let node trust it so the API
# can reach accounts.google.com:
NODE_EXTRA_CA_CERTS=/Users/abhimanyusinghrathore/certs/ca-bundle-with-zscaler.pem
