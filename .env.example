# Copy to .env to enable REAL SSO login locally (`make start` reads it).
# Without a .env, `make start` runs in dev-auth mode (no IdP needed).
# Login is generic OIDC — Google is just the DEFAULT issuer. See SETUP_SSO.md
# for Okta / Entra ID / Keycloak / Authentik recipes and a local `make keycloak`.

# Turn OFF dev-auth so the server-mediated OIDC flow is used.
DROP_DEV_AUTH=0

# --- Provider (generic OIDC) -------------------------------------------------
# The issuer's /.well-known/openid-configuration is discovered at boot.
# Default is Google; point it at any OIDC IdP to switch providers.
# DROP_OIDC_ISSUER=https://accounts.google.com

# OAuth client id/secret. These fall back to the legacy DROP_GOOGLE_CLIENT_ID/SECRET
# below, so an existing Google deployment keeps working with ZERO changes.
# DROP_OIDC_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# DROP_OIDC_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Legacy Google vars — still honored (DROP_OIDC_* wins when both are set).
DROP_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
DROP_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Optional claim/scope/label tuning (defaults shown):
# DROP_OIDC_SCOPES=openid email profile
# DROP_OIDC_EMAIL_CLAIM=email        # Entra ID often needs preferred_username
# DROP_OIDC_NAME_CLAIM=name
# DROP_OIDC_DISPLAY_NAME=Google      # provider name on the sign-in button (default: derived from issuer host)

# Optional group gate — require membership in a group (claim is an array or space-joined string):
# DROP_OIDC_GROUPS_CLAIM=groups
# DROP_OIDC_REQUIRED_GROUP=drop-users

# Must match the API's URL; its /auth/callback is the registered redirect URI.
# (8473 is the Makefile's default API port; change both together if you override it.)
DROP_PUBLIC_URL=http://localhost:8473

# Random secret that signs Drop session tokens.  Generate:  openssl rand -hex 32
DROP_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Restrict to your domain (empty = any account from the issuer). Falls back to
# DROP_ALLOWED_DOMAINS when DROP_OIDC_ALLOWED_DOMAINS is unset.
DROP_ALLOWED_DOMAINS=example.com
# DROP_OIDC_ALLOWED_DOMAINS=example.com

# Optional: restrict to specific people (comma-separated). Empty = no per-email
# limit (domain rule still applies). Applied on top of the domain gate.
# DROP_ALLOWED_EMAILS=admin@example.com,teammate@example.com

# --- Break-glass admin (emergency local login) -------------------------------
# The ONE local email/password account, for access when the IdP is down. OFF unless set.
# No signup, no reset. Format "email:saltHex:hashHex" (scrypt). Generate with:
#   node -e 'const c=require("node:crypto"),[e,p]=process.argv.slice(1),s=c.randomBytes(16),k=c.scryptSync(p,s,64);console.log(`${e.toLowerCase()}:${s.toString("hex")}:${k.toString("hex")}`)' admin@example.com 'your-password'
# DROP_BREAK_GLASS_ADMIN=admin@example.com:...:...

# If your network does TLS inspection, let node trust it so the API
# can reach the OIDC issuer:
NODE_EXTRA_CA_CERTS=/path/to/certs/ca-bundle.pem

# EDGE only: cache asset bytes on local disk (node-local / per-pod dir; off if unset).
# Memory holds just the version pointer — asset bytes go to disk + OS page cache.
# DROP_EDGE_DISK_CACHE=/var/cache/drop
# DROP_EDGE_DISK_CACHE_BYTES=5368709120   # 5 GiB

# EDGE only: WebSocket tunnelling limits (type=app upgrades pass through the edge).
# DROP_WS_MAX_PER_HOST=100                 # per-host concurrent-upgrade cap
# DROP_WS_IDLE_TIMEOUT_MS=300000           # idle timeout (5 min) — destroys both sockets
# DROP_WS_DIRECT=1                         # dial the app Service directly (wake shim) instead of the interceptor
