    "/v1/sites/{name}/versions": {
      "post": {
        "operationId": "publishSiteVersion",
        "summary": "Publish a new static-site version from a gzipped tarball; flips the live pointer (or a preview).",
        "tags": [
          "sites"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "org",
            "in": "query",
            "required": false,
            "description": "Owning org slug when first claiming the name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "preview",
            "in": "query",
            "required": false,
            "description": "Publish as a named preview instead of flipping current_version.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expire_days",
            "in": "query",
            "required": false,
            "description": "Preview lifetime in days (default 7).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "A gzipped tarball of the site's files.",
          "content": {
            "application/gzip": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "files": {
                      "type": "number"
                    },
                    "bytes": {
                      "type": "number"
                    },
                    "preview": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "type": "string"
                        },
                        "url": {
                          "type": "string"
                        },
                        "versionId": {
                          "type": "string"
                        },
                        "expiresAt": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "label",
                        "url",
                        "versionId",
                        "expiresAt"
                      ]
                    }
                  },
                  "required": [
                    "url",
                    "version",
                    "files",
                    "bytes"
                  ]
                }
              }
            }
          }
        }
