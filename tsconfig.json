{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "lib": ["ESNext"]
  },
  "include": ["src", "bin", "e2e", "build.mjs"],
  "exclude": ["node_modules", "dist", "examples", "console"]
}
