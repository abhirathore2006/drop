# Keep the build context lean and safe. Excludes host node_modules and .env
# (secrets). dist/ IS included — the images copy the prebuilt esbuild bundles
# (run `node build.mjs` before building the images).
**/node_modules
.git
.gitignore
.env
*.log
.run
infra/nginx/certs
infra/nginx/.verify.conf
docs/superpowers
