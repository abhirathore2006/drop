# Build from drop/: podman build -f deploy/Dockerfile.api -t drop-api .
FROM docker.io/oven/bun:1
WORKDIR /app
COPY package.json bun.lock* ./
# --production: runtime deps only, and skips the CLI's prepare/build step
RUN bun install --production --frozen-lockfile || bun install --production
COPY . .
EXPOSE 8080
CMD ["bun", "run", "bin/api.ts"]
