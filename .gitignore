node_modules/
dist/
.env
*.log
.run/

# nginx local TLS certs (generated by infra/nginx/gen-certs.sh)
infra/nginx/certs/*.pem
infra/nginx/.verify.conf

# organization root CAs (drop *.crt here to trust them in the image; never committed)
infra/ca/*
!infra/ca/.gitkeep
!infra/ca/README.md

