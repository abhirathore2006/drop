# Local dev (dev-auth, Floci). Copy to .env and adjust for non-compose runs.
DROP_HTTP_PORT=8080
DROP_BASE_DOMAIN=drop.localhost
DROP_S3_BUCKET=drop-sites
DROP_S3_ENDPOINT=http://localhost:4566
DROP_S3_REGION=us-east-1
DROP_S3_KEY_ID=test
DROP_S3_SECRET=test
DROP_DEV_AUTH=1

# Production (Google login) — leave DROP_DEV_AUTH unset/0 and set:
# DROP_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# DROP_GOOGLE_CLIENT_SECRET=...
# DROP_ALLOWED_DOMAINS=paytm.com
# DROP_S3_ENDPOINT=        # leave empty for real AWS S3
