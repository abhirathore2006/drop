<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= title %> · blog · drop</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    :root{color-scheme:dark}
    *{box-sizing:border-box}
    body{font:16px/1.5 ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,sans-serif;max-width:680px;margin:48px auto;padding:0 20px;background:#0b0d10;color:#e7e9ea}
    a{color:#9be15d;text-decoration:none}a:hover{text-decoration:underline}
    h1{font-size:26px;margin:0 0 4px}h2{font-size:20px;margin:0}
    .sub{color:#8a9099;margin:0 0 24px;font-size:14px}
    .topbar{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:24px}
    .btn{display:inline-block;padding:9px 16px;border-radius:10px;border:0;background:#9be15d;color:#0b0d10;font-weight:600;cursor:pointer;font:inherit}
    .btn.ghost{background:#11151a;color:#e7e9ea;border:1px solid #2a2f37}
    .btn.danger{background:#11151a;color:#ef6b6b;border:1px solid #3a2226}
    .btn.danger:hover{background:#ef4444;color:#0b0d10}
    form{margin:0}
    .field{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
    .field label{font-size:13px;color:#8a9099}
    .field input,.field textarea{padding:11px 13px;border-radius:10px;border:1px solid #2a2f37;background:#11151a;color:inherit;font:inherit}
    .field textarea{min-height:180px;resize:vertical}
    .actions{display:flex;gap:10px;align-items:center;margin-top:8px}
    ul.posts{list-style:none;padding:0;margin:0}
    ul.posts li{padding:14px 16px;border:1px solid #1c2128;border-radius:12px;margin-bottom:10px;background:#11151a}
    ul.posts .meta{font-size:13px;color:#8a9099;margin-top:4px}
    .excerpt{margin:6px 0 0;color:#c2c7cd}
    article p{white-space:pre-wrap;margin:16px 0}
    .meta{font-size:13px;color:#8a9099}
    .errors{border:1px solid #3a2226;background:#1a1012;color:#ef9b9b;border-radius:10px;padding:10px 14px;margin-bottom:16px;font-size:14px}
    .errors ul{margin:4px 0 0;padding-left:18px}
    footer{margin-top:32px;color:#6b7280;font-size:13px;border-top:1px solid #1c2128;padding-top:16px}
  </style>
</head>
<body>
  <div class="topbar">
    <h1><a href="/" style="color:inherit">▸ blog</a></h1>
    <a class="btn" href="/posts/new">+ new post</a>
  </div>
