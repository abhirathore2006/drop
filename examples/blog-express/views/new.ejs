<%- include("partials/header", { title: "New post" }) %>

<p class="sub"><a href="/">← all posts</a></p>
<h1>New post</h1>

<% if (errors.length) { %>
  <div class="errors">Could not save:<ul><% errors.forEach(function (e) { %><li><%= e %></li><% }) %></ul></div>
<% } %>

<form method="post" action="/posts">
  <div class="field">
    <label for="title">Title</label>
    <input id="title" name="title" maxlength="200" autocomplete="off" value="<%= post.title %>" autofocus>
  </div>
  <div class="field">
    <label for="body">Body</label>
    <textarea id="body" name="body"><%= post.body %></textarea>
  </div>
  <div class="actions">
    <button class="btn" type="submit">publish</button>
    <a class="btn ghost" href="/">cancel</a>
  </div>
</form>

<%- include("partials/footer") %>
